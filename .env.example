# Google AI Studio API key. Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Optional — override the source repo / branch being ingested
SOURCE_REPO=hashemkhodor/collegesaurus
SOURCE_BRANCH=main

# Optional — Supabase chat-log store. If unset, chat still works but no
# rows are written. Get both from Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
